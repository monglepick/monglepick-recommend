# =========================================
# 몽글픽 추천 서비스 환경변수 템플릿
# =========================================
# 이 파일을 .env 로 복사한 뒤 실제 값을 입력하세요.
# cp .env.example .env

# -----------------------------------------
# MySQL (Spring Boot 백엔드와 공유)
# -----------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=monglepick
DB_USERNAME=monglepick
DB_PASSWORD=monglepick

# -----------------------------------------
# Redis
# -----------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# -----------------------------------------
# JWT (Spring Boot 백엔드와 동일한 시크릿 사용)
# -----------------------------------------
JWT_SECRET=your-256-bit-secret-key-change-in-production
JWT_ALGORITHM=HS256

# -----------------------------------------
# 서버
# -----------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8001

# -----------------------------------------
# CORS 허용 오리진
# -----------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------
# TMDB 이미지 베이스 URL
# -----------------------------------------
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500
