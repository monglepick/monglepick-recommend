# =========================================
# 몽글픽 추천 서비스 환경변수 템플릿
# =========================================
# 이 파일을 .env 로 복사한 뒤 실제 값을 입력하세요.
# cp .env.example .env

# -----------------------------------------
# 애플리케이션 기본 설정
# -----------------------------------------
APP_NAME=monglepick-recommend
APP_VERSION=0.1.0
DEBUG=true
API_V1_PREFIX=/api/v1

# -----------------------------------------
# MySQL (Spring Boot 백엔드와 공유)
# -----------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# -----------------------------------------
# Redis
# -----------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# -----------------------------------------
# JWT (Spring Boot 백엔드와 동일한 시크릿 사용)
# -----------------------------------------
JWT_SECRET=replace_with_real_jwt_secret
JWT_ALGORITHM=HS256

# -----------------------------------------
# 서버
# -----------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8001

# -----------------------------------------
# CORS 허용 오리진
# -----------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------
# TMDB 이미지 베이스 URL
# -----------------------------------------
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500
